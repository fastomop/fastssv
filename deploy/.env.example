# FastSSV deploy-time configuration.
#
# Copy this file to `deploy/.env` (or the repo root, picked up by docker compose)
# and override values as needed. All variables have sane defaults baked into
# `deploy/docker-compose.yml`, so this file is purely for convenience and
# documentation — empty values fall back to those defaults.
#
# Usage:
#   cp deploy/.env.example deploy/.env
#   # edit deploy/.env
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up

# -----------------------------------------------------------------------------
# Compose / runtime
# -----------------------------------------------------------------------------

# Host port the API is published on. Container always listens on 8000.
FASTSSV_PORT=8000

# Number of gunicorn worker processes. Tune for the deploy box: typical guidance
# is `2 * CPU + 1`. Each worker holds the rule registry in memory (~10 MB).
WEB_CONCURRENCY=2

# -----------------------------------------------------------------------------
# API behavior (read by `fastssv.api.config.Settings`, prefix FASTSSV_API_)
# -----------------------------------------------------------------------------

# Log level for the FastAPI app. One of DEBUG / INFO / WARNING / ERROR / CRITICAL.
FASTSSV_API_LOG_LEVEL=INFO

# Per-IP rate limit applied by slowapi to /v1/validate. Format: "<count>/<window>".
# Examples: "60/minute", "1000/hour", "10/second".
FASTSSV_API_RATE_LIMIT=60/minute

# Max bytes accepted for a single SQL submission. Requests exceeding this are
# rejected with HTTP 413 by the body-size middleware before parsing.
FASTSSV_API_MAX_SQL_BYTES=100000

# Wall-clock timeout for sqlglot parsing of a single submission. Fractional
# seconds allowed. Long parses are killed and surfaced as a parse error.
FASTSSV_API_PARSE_TIMEOUT_SECONDS=5

# Comma-separated list of allowed CORS origins for the JSON API.
# Empty (the default) means no cross-origin browser requests are accepted.
# For the HTMX UI served by the same app, same-origin requests work without CORS.
# Example: FASTSSV_API_CORS_ORIGINS=https://example.com,https://staging.example.com
FASTSSV_API_CORS_ORIGINS=

# Trust X-Forwarded-* headers from a reverse proxy (e.g. nginx, Traefik, Caddy)
# in front of the container. Enable when terminating TLS upstream so generated
# URLs reflect the external https scheme/host. Disable if exposing the
# container directly to clients. The compose file defaults this to "true";
# the in-code default (when running outside compose) is "false".
FASTSSV_API_BEHIND_PROXY=true
